# mcp-edge example

MCP_PLATFORM_ENV=production
MCP_PLATFORM_LOG_LEVEL=info
MCP_PLATFORM_DATABASE_URL=file:/data/mcp-platform/mcp-platform.db

MCP_EDGE_HTTP_BIND_ADDR=:8080
MCP_EDGE_PUBLIC_BASE_URL=https://mcp.example.com

MCP_EDGE_AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/mcp-edge/
MCP_EDGE_AUTHENTIK_CLIENT_ID=mcp-edge
MCP_EDGE_AUTHENTIK_CLIENT_SECRET_PATH=/run/secrets/mcp-edge-authentik-client-secret

MCP_EDGE_OPERATOR_TOKEN_PATH=/run/secrets/mcp-edge-operator-token
MCP_EDGE_SESSION_ENCRYPTION_KEY_PATH=/run/secrets/mcp-edge-session-encryption-key
MCP_EDGE_COOKIE_SECURE=true

# Development only. Do not enable in production.
# MCP_EDGE_ENABLE_FIXTURE_MODE=false
