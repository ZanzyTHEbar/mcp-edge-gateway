# mcp-control-plane production example

MCP_PLATFORM_ENV=production
MCP_PLATFORM_LOG_LEVEL=info
MCP_PLATFORM_DATABASE_URL=postgres://mcp_platform:CHANGE_ME@mcp-platform-db:5432/mcp_platform?sslmode=disable

MCP_CONTROL_PLANE_HTTP_BIND_ADDR=:8081
MCP_CONTROL_PLANE_RECONCILE_INTERVAL=30s
MCP_CONTROL_PLANE_HEALTHCHECK_INTERVAL=30s

MCP_CONTROL_PLANE_AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/mcp-control-plane/
MCP_CONTROL_PLANE_AUTHENTIK_CLIENT_ID=mcp-control-plane
MCP_CONTROL_PLANE_AUTHENTIK_CLIENT_SECRET_PATH=/platform/mcp-control-plane/authentik-client-secret

MCP_CONTROL_PLANE_COOLIFY_API_BASE_URL=https://coolify.example.com/api/v1
MCP_CONTROL_PLANE_COOLIFY_API_TOKEN_PATH=/platform/mcp-control-plane/coolify-api-token
MCP_CONTROL_PLANE_COOLIFY_PROJECT_UUID=REPLACE_WITH_COOLIFY_PROJECT_UUID
MCP_CONTROL_PLANE_COOLIFY_ENVIRONMENT_UUID=REPLACE_WITH_COOLIFY_ENVIRONMENT_UUID
# MCP_CONTROL_PLANE_COOLIFY_ENVIRONMENT_NAME=production
MCP_CONTROL_PLANE_COOLIFY_SERVER_UUID=REPLACE_WITH_COOLIFY_SERVER_UUID
MCP_CONTROL_PLANE_COOLIFY_DESTINATION_UUID=REPLACE_WITH_COOLIFY_DESTINATION_UUID

MCP_CONTROL_PLANE_INFISICAL_API_BASE_URL=http://infisical-bridge:8080
MCP_CONTROL_PLANE_INFISICAL_PROJECT_SLUG=example-project
MCP_CONTROL_PLANE_INFISICAL_ENV_SLUG=prod
MCP_CONTROL_PLANE_INFISICAL_MACHINE_CLIENT_ID=REPLACE_WITH_INFISICAL_MACHINE_CLIENT_ID
MCP_CONTROL_PLANE_INFISICAL_MACHINE_CLIENT_SECRET_PATH=/run/secrets/mcp-control-plane-infisical-machine-client-secret

# These upstream URLs must be reachable from tenant containers.
MCP_CONTROL_PLANE_MEALIE_BASE_URL=https://mealie.example.com
MCP_CONTROL_PLANE_ACTUAL_SERVER_URL=https://budget.example.com

# Optional image overrides. Leave unset to use the built-in defaults.
# MCP_CONTROL_PLANE_TENANT_IMAGE_MEALIE=ghcr.io/zanzythebar/mealie-mcp:latest
# MCP_CONTROL_PLANE_TENANT_IMAGE_ACTUALBUDGET=ghcr.io/zanzythebar/actual-mcp-server:latest
# MCP_CONTROL_PLANE_TENANT_IMAGE_MEMORY=ghcr.io/zanzythebar/mcp-memory-libsql-go:latest
